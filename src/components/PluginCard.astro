---
import CopyButton from './CopyButton.astro'
import type { ShellTranslation, SiteConfig, Plugin } from '../types'
import { marketplaceSlugOf, pluginInstallCommand } from '../i18n'

interface Props {
  t: ShellTranslation
  site: SiteConfig
  plugin: Plugin
}

const { t, site, plugin } = Astro.props
const meta = t.plugin_meta[plugin.code] ?? { name: plugin.code, tag: '', lang_value: '' }
const agentDict: Record<string, string> = t.agents[plugin.code] ?? {}
const skillDict: Record<string, string> = t.skills[plugin.code] ?? {}
const slug = site.marketplaceSlug ?? marketplaceSlugOf(site.repo)
const installCmd = pluginInstallCommand(plugin.code, slug)
---

<article class="plugin-card">
  <div class="head">
    <div>
      <div class="tag">{meta.tag}</div>
      <h3 class="name">{meta.name}</h3>
      <div class="code">/{plugin.code}:…</div>
    </div>
    {plugin.flag && typeof plugin.flag === 'string' && (
      <Fragment set:html={plugin.flag} />
    )}
  </div>

  <div class="meta">
    <div class="meta-cell">
      <div class="meta-label">{t.plugins.commands}</div>
      <div class="meta-value meta-mono">/{plugin.code}:…</div>
    </div>
    <div class="meta-cell meta-cell-last">
      <div class="meta-label">{t.plugins.lang}</div>
      <div class="meta-value">{meta.lang_value}</div>
    </div>
  </div>

  <div class="list-head">
    <span>{t.plugins.agents}</span>
    <span class="count">{plugin.agents.length}</span>
  </div>
  <div class="agent-list">
    {plugin.agents.map((k) => (
      <div class="agent-item">{agentDict[k] ?? k}</div>
    ))}
  </div>

  <div class="list-head skills-head">
    <span>{t.plugins.skills}</span>
    <span class="count">{plugin.skills.length}</span>
  </div>
  <div class="agent-list skill-list">
    {plugin.skills.map((k) => (
      <div class="agent-item">{skillDict[k] ?? k}</div>
    ))}
  </div>

  <div class="install-row">
    <div class="install-code">
      <span class="prompt" aria-hidden="true">›</span>
      <span class="install-code-text">{installCmd}</span>
      <CopyButton
        text={installCmd}
        labelCopy={t.hero.install_copy}
        labelDone={t.hero.install_done}
        size="sm"
      />
    </div>
  </div>
</article>

<style>
  .plugin-card {
    border: 1px solid var(--rule);
    border-radius: var(--rad-lg);
    background: var(--bg-2);
    padding: 28px;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-auto-rows: min-content;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .plugin-card:hover {
    border-color: var(--rule-strong);
  }
  @media (max-width: 600px) {
    .plugin-card {
      padding: 22px;
    }
  }

  .head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-top: 4px;
  }
  .name {
    font-family: var(--font-display);
    font-size: 36px;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    font-weight: 400;
  }
  @media (max-width: 600px) {
    .name {
      font-size: 28px;
    }
  }
  .code {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    margin-top: 6px;
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin: 4px 0 20px;
  }
  .meta-cell {
    padding: 12px 0;
    border-right: 1px solid var(--rule);
    padding-right: 14px;
  }
  .meta-cell-last {
    border-right: none;
    padding-left: 14px;
    padding-right: 0;
  }
  .meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 4px;
  }
  .meta-value {
    font-size: 14px;
    color: var(--ink);
  }
  .meta-mono {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
  }

  .list-head {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 12px 0 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .skills-head {
    margin-top: 18px;
  }
  .count {
    color: var(--ink);
    font-size: 12px;
    font-family: var(--font-mono);
  }

  .agent-list {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: 16px;
    row-gap: 4px;
    margin-bottom: 4px;
  }
  @media (max-width: 960px) {
    .agent-list {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  .agent-item {
    padding: 6px 0;
    border-bottom: 1px dashed var(--rule);
    font-size: 13px;
    color: var(--ink);
  }

  .install-row {
    display: flex;
    gap: 8px;
    margin-top: 20px;
    flex-wrap: wrap;
    align-self: end;
  }
  .install-code {
    flex: 1;
    min-width: 200px;
    background: var(--code-bg);
    border: 1px solid var(--rule);
    border-radius: var(--rad-md);
    font-family: var(--font-mono);
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 14px;
    overflow: hidden;
  }
  .prompt {
    color: var(--accent);
    user-select: none;
    flex-shrink: 0;
  }
  .install-code-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--ink);
  }
</style>
