---
import type { ShellTranslation } from '../types'

interface Props {
  t: ShellTranslation
}

const { t } = Astro.props
---

<section class="section" id="principles">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">{t.principles.eyebrow}</div>
        <h2>{t.principles.title}</h2>
      </div>
      <p></p>
    </div>
    <div class="list">
      {t.principles.items.map((item, i) => (
        <div class="row">
          <div class="num">{String(i + 1).padStart(2, '0')}</div>
          <div class="k">{item.k}</div>
          <div class="v">{item.v}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .list {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--rule);
  }
  .row {
    display: grid;
    grid-template-columns: 80px 1fr 2fr;
    gap: 32px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
  }
  @media (max-width: 960px) {
    .row {
      grid-template-columns: 60px 1fr;
      gap: 16px;
    }
    .v {
      grid-column: 1 / -1;
      padding-left: 0;
    }
  }
  @media (max-width: 600px) {
    .row {
      grid-template-columns: 48px 1fr;
      gap: 14px;
      padding: 18px 0;
    }
  }
  .num {
    font-family: var(--font-display);
    font-size: 34px;
    color: var(--accent);
    font-style: italic;
    line-height: 1;
  }
  @media (max-width: 600px) {
    .num {
      font-size: 26px;
    }
  }
  .k {
    font-family: var(--font-display);
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-wrap: balance;
  }
  @media (max-width: 600px) {
    .k {
      font-size: 19px;
    }
  }
  .v {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.6;
    text-wrap: pretty;
  }
</style>
