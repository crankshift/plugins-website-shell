---
import CopyButton from './CopyButton.astro'
import type { ShellTranslation, SiteConfig } from '../types'
import {
  marketplaceAddCommand,
  marketplaceSlugOf,
  pluginInstallCommand,
  reloadCommand,
} from '../i18n'

interface Props {
  t: ShellTranslation
  site: SiteConfig
}

const { t, site } = Astro.props

const MARKETPLACE = marketplaceAddCommand(site.repo, site.marketplaceInstall)
const RELOAD = reloadCommand(site.reloadCmd)
const slug = site.marketplaceSlug ?? marketplaceSlugOf(site.repo)

type TabEntry = { key: string; label: string; commands: readonly string[] }

const perPlugin: TabEntry[] = site.plugins.map((p) => ({
  key: p.code,
  label: p.code.toUpperCase(),
  commands: [MARKETPLACE, pluginInstallCommand(p.code, slug), RELOAD],
}))

const allTab: TabEntry | null = site.plugins.length >= 2
  ? {
      key: 'all',
      label: site.plugins.map((p) => p.code.toUpperCase()).join(' + '),
      commands: [
        MARKETPLACE,
        ...site.plugins.map((p) => pluginInstallCommand(p.code, slug)),
        RELOAD,
      ],
    }
  : null

const TABS: readonly TabEntry[] = allTab ? [...perPlugin, allTab] : perPlugin
const DEFAULT_TAB_KEY = allTab ? 'all' : perPlugin[0]?.key ?? ''
---

<section class="section" id="install">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">{t.install.eyebrow}</div>
        <h2>{t.install.title}</h2>
      </div>
      <p>{t.install.sub}</p>
    </div>

    <div class="prereq">
      <div class="prereq-head">
        <h3>{t.install.prereq_heading}</h3>
        <p>{t.install.prereq_sub}</p>
      </div>
      <div class="prereq-grid">
        <a
          class="prereq-card"
          href="https://code.claude.com/docs/en/quickstart"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="prereq-pill">CLI</div>
          <h4>{t.install.cli_title}</h4>
          <p>{t.install.cli_body}</p>
          <span class="prereq-cta">
            {t.install.cli_cta}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M4 2H2v8h8V8M6 2h4v4M10 2 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
        <a
          class="prereq-card"
          href="https://claude.ai/download"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="prereq-pill">GUI</div>
          <h4>{t.install.desktop_title}</h4>
          <p>{t.install.desktop_body}</p>
          <span class="prereq-cta">
            {t.install.desktop_cta}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M4 2H2v8h8V8M6 2h4v4M10 2 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
        <a
          class="prereq-card prereq-card-rec"
          href="https://code.visualstudio.com/download"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="prereq-badge">{t.install.vscode_badge}</div>
          <h4>{t.install.vscode_title}</h4>
          <p>{t.install.vscode_body}</p>
          <ol class="prereq-steps">
            <li>{t.install.vscode_step1}</li>
            <li>{t.install.vscode_step2}</li>
          </ol>
          <span class="prereq-cta">
            {t.install.vscode_cta}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M4 2H2v8h8V8M6 2h4v4M10 2 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
      </div>
    </div>

    <div class="terminal">
      <div class="terminal-head">
        <div class="dots" aria-hidden="true">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <span class="terminal-title">claude — {t.install.pick}</span>
        <div class="tabs" role="tablist" aria-label={t.install.pick}>
          {TABS.map((tab) => (
            <button
              type="button"
              class:list={['tab', { on: tab.key === DEFAULT_TAB_KEY }]}
              role="tab"
              data-tab={tab.key}
              aria-selected={tab.key === DEFAULT_TAB_KEY ? 'true' : 'false'}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      <div class="terminal-body">
        <div class="line">
          <span class="comment"># {t.install.step1}</span>
        </div>

        {TABS.map((tab) => {
          const [step1, ...rest] = tab.commands
          return (
            <div class="tab-panel" data-panel={tab.key} hidden={tab.key !== DEFAULT_TAB_KEY}>
              <div class="line">
                <span class="prompt" aria-hidden="true">›</span>
                <span class="cmd">{step1}</span>
                <CopyButton
                  text={step1!}
                  labelCopy={t.hero.install_copy}
                  labelDone={t.hero.install_done}
                  size="sm"
                />
              </div>
              <div class="spacer"></div>
              <div class="line">
                <span class="comment"># {t.install.step2}</span>
              </div>
              {rest.map((line) => (
                <div class="line">
                  <span class="prompt" aria-hidden="true">›</span>
                  <span class="cmd">{line}</span>
                  <CopyButton
                    text={line}
                    labelCopy={t.hero.install_copy}
                    labelDone={t.hero.install_done}
                    size="sm"
                  />
                </div>
              ))}
            </div>
          )
        })}

      </div>
    </div>

    <p class="verify-line">
      <span class="mono-inline">/plugin</span>
      {' · '}
      <span class="mono-inline">/agents</span>
      {' — '}
      {t.install.verify_line}
    </p>
  </div>
</section>

<script>
  const section = document.getElementById('install')
  if (section) {
    const tabs = section.querySelectorAll<HTMLButtonElement>('.tab')
    const panels = section.querySelectorAll<HTMLElement>('.tab-panel')
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.dataset.tab
        tabs.forEach((t) => {
          const isOn = t.dataset.tab === key
          t.classList.toggle('on', isOn)
          t.setAttribute('aria-selected', String(isOn))
        })
        panels.forEach((panel) => {
          panel.hidden = panel.dataset.panel !== key
        })
      })
    })
  }
</script>

<style>
  .terminal {
    border: 1px solid var(--rule);
    border-radius: var(--rad-lg);
    background: var(--bg-2);
    overflow: hidden;
    margin-top: 28px;
  }
  .terminal-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--rule);
    background: var(--bg-3);
  }
  .dots {
    display: flex;
    gap: 6px;
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--rule-strong);
  }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
    margin-left: 10px;
  }
  .tabs {
    margin-left: auto;
    display: flex;
    gap: 4px;
  }
  .tab {
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: var(--rad-pill);
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    cursor: pointer;
  }
  .tab.on {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }

  .terminal-body {
    padding: 24px 20px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
  }
  @media (max-width: 600px) {
    .terminal-body {
      padding: 16px 14px;
      font-size: 12px;
    }
  }
  .line {
    display: flex;
    gap: 8px;
    align-items: baseline;
    padding: 3px 0;
  }
  .spacer {
    height: 8px;
  }
  .prompt {
    color: var(--accent);
  }
  .cmd {
    color: var(--ink);
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    white-space: nowrap;
  }
  .comment {
    color: var(--ink-3);
  }

  .prereq {
    margin-bottom: 28px;
  }
  .prereq-head {
    margin-bottom: 20px;
  }
  .prereq-head h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 26px;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .prereq-head p {
    margin: 0;
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.55;
  }

  .prereq-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 960px) {
    .prereq-grid {
      grid-template-columns: 1fr;
    }
  }

  .prereq-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 1px solid var(--rule);
    border-radius: var(--rad-md);
    padding: 20px;
    background: var(--bg-2);
    color: var(--ink);
    transition: border-color 0.15s, transform 0.15s;
    position: relative;
  }
  .prereq-card:hover {
    border-color: var(--rule-strong);
    transform: translateY(-1px);
  }
  .prereq-card h4 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .prereq-card p {
    margin: 0;
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
    flex: 1;
  }
  .prereq-pill {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    border: 1px solid var(--rule);
    border-radius: var(--rad-pill);
    padding: 3px 10px;
  }
  .prereq-steps {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    counter-reset: prereq-step;
  }
  .prereq-steps li {
    counter-increment: prereq-step;
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr);
    gap: 10px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-2);
  }
  .prereq-steps li::before {
    content: counter(prereq-step);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--rule));
    border-radius: var(--rad-pill);
    width: 22px;
    height: 22px;
    display: inline-grid;
    place-items: center;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .prereq-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--accent);
    margin-top: 4px;
  }

  .prereq-card-rec {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--rule));
    background: color-mix(in srgb, var(--accent) 6%, var(--bg-2));
  }
  :root[data-theme='dark'] .prereq-card-rec {
    background: color-mix(in srgb, var(--accent) 12%, var(--bg-3));
  }
  .prereq-card-rec:hover {
    border-color: var(--accent);
  }
  .prereq-badge {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    border-radius: var(--rad-pill);
    padding: 3px 10px;
    font-weight: 600;
  }
  :root[data-theme='dark'] .prereq-badge {
    color: var(--bg);
  }

  .verify-line {
    margin: 32px 0 0;
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .mono-inline {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--code-bg);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent);
  }
</style>
